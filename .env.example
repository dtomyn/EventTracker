EVENTTRACKER_HOST=127.0.0.1
EVENTTRACKER_PORT=35231

# Draft generation provider: `openai` or `copilot`.
# Most users should leave this as `openai` unless they have installed the
# GitHub Copilot SDK and want draft generation to run through Copilot.
EVENTTRACKER_AI_PROVIDER=openai

# OpenAI-compatible settings used for draft generation in `openai` mode and
# for semantic embeddings regardless of the draft provider.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_CHAT_MODEL_ID=
OPENAI_EMBEDDING_MODEL_ID=

# Copilot draft-generation settings used only when
# EVENTTRACKER_AI_PROVIDER=copilot.
# See README.md for Copilot SDK runtime notes and local validation gotchas.
COPILOT_CHAT_MODEL_ID=gpt-5

# Optional timeouts for the Copilot-powered timeline web search sidebar.
# The backend search defaults to 60 seconds, the broadened retry defaults to
# 45 seconds, and the browser request timeout defaults to the larger backend
# timeout plus 5 seconds.
EVENTTRACKER_GROUP_WEB_SEARCH_TIMEOUT_SECONDS=
EVENTTRACKER_GROUP_WEB_SEARCH_BROADENED_TIMEOUT_SECONDS=
EVENTTRACKER_GROUP_WEB_SEARCH_REQUEST_TIMEOUT_MS=

# Advanced optional override: path to the Copilot CLI executable.
# Leave blank if `copilot` already works on your PATH.
COPILOT_CLI_PATH=

# Advanced optional override: URL for an already running Copilot CLI server,
# for example `localhost:8080`. Leave blank for normal local usage so the SDK
# can manage the CLI process itself.
COPILOT_CLI_URL=
