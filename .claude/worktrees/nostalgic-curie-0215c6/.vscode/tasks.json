{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run EventTracker",
			"type": "shell",
			"command": "uv",
			"args": [
				"run",
				"python",
				"-m",
				"scripts.run_dev",
				"--reload"
			],
			"isBackground": true,
			"problemMatcher": [
				{
					"pattern": [
						{
							"regexp": ".",
							"file": 1,
							"location": 2,
							"message": 3
						}
					],
					"background": {
						"activeOnStart": true,
						"beginsPattern": "INFO:\\s+Will watch for changes",
						"endsPattern": "INFO:\\s+Application startup complete\\."
					}
				}
			],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": true
			}
		},
		{
			"label": "Run EventTracker review session",
			"type": "shell",
			"command": "uv",
			"args": [
				"run",
				"python",
				"-m",
				"scripts.run_dev"
			],
			"isBackground": true
		},
		{
			"label": "Type Check EventTracker",
			"type": "shell",
			"command": "uv",
			"args": [
				"run",
				"pyright"
			],
			"problemMatcher": []
		}
	]
}